{% schema %}
{
  "name": "Pasek ogłoszeń",
  "blocks": [
    {
      "type": "item",
      "name": "Tekst",
      "settings": [
        { "type": "text", "id": "text", "label": "Treść", "default": "NOWY TEKST" },
        { "type": "checkbox", "id": "show_dot", "label": "Separator · po tekście", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pasek ogłoszeń",
      "blocks": [
        { "type": "item", "settings": { "text": "BIEGAM PO BUŁKI", "show_dot": true } },
        { "type": "item", "settings": { "text": "RUN. EAT. REPEAT.", "show_dot": true } },
        { "type": "item", "settings": { "text": "DROP 001 · KOLEKCJA LIMITOWANA", "show_dot": true } },
        { "type": "item", "settings": { "text": "DARMOWA DOSTAWA OD 300 ZŁ", "show_dot": true } },
        { "type": "item", "settings": { "text": "1 BIEG = 1 ZŁ NA CELE CHARYTATYWNE", "show_dot": true } },
        { "type": "item", "settings": { "text": "WYSYŁKA W 2–3 DNI ROBOCZE", "show_dot": true } },
        { "type": "item", "settings": { "text": "@roadandrolls", "show_dot": true } }
      ]
    }
  ]
}
{% endschema %}
