<div class="ann-bar">
  <div class="ann-track">
    {% if section.blocks.size > 0 %}
      {% for block in section.blocks %}{% if block.type == 'item' %}<span class="ann-item" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>{% if block.settings.show_dot %}<span class="ann-item ann-dot">·</span>{% endif %}{% endif %}{% endfor %}
      {% for block in section.blocks %}{% if block.type == 'item' %}<span class="ann-item">{{ block.settings.text }}</span>{% if block.settings.show_dot %}<span class="ann-item ann-dot">·</span>{% endif %}{% endif %}{% endfor %}
    {% else %}
      <span class="ann-item">BIEGAM PO BUŁKI</span><span class="ann-item ann-dot">·</span>
      <span class="ann-item">RUN. EAT. REPEAT.</span><span class="ann-item ann-dot">·</span>
