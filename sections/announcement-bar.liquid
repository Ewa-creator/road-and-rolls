      <span class="ann-item">WYSYŁKA W 2–3 DNI ROBOCZE</span><span class="ann-item ann-dot">·</span>
      <span class="ann-item">@roadandrolls</span><span class="ann-item ann-dot">·</span>
      <span class="ann-item">BIEGAM PO BUŁKI</span><span class="ann-item ann-dot">·</span>
      <span class="ann-item">RUN. EAT. REPEAT.</span><span class="ann-item ann-dot">·</span>
