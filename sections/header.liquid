<nav class="nav" id="mainNav">
  <a href="{{ routes.root_url }}" class="nav-logo">Road <span>&</span> Rolls</a>
  <div class="nav-links">
    <a href="{{ routes.root_url }}" class="nav-link">Strona główna</a>
    <a href="mailto:{{ section.settings.contact_email | default: 'kontakt@roadandrolls.pl' }}" class="nav-link">Kontakt</a>
    <a href="#o-nas" class="nav-link">O nas</a>
  </div>
  <div class="nav-icons">
    <button class="nav-icon-btn" aria-label="Szukaj">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </button>
    <a href="{{ routes.account_url }}" class="nav-icon-btn" aria-label="Konto">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6"/></svg>
    </a>
    <button class="nav-icon-btn" id="cartBtn" aria-label="Koszyk" onclick="toggleCart()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 8h12l-1 12H7L6 8z"/><path d="M9 8V6a3 3 0 016 0v2"/></svg>
      <span class="cart-count" id="cartCount" data-zero="true">0</span>
    </button>
  </div>
</nav>

{% schema %}
{
  "name": "Nawigacja",
  "settings": [
    {
      "type": "text",
      "id": "contact_email",
      "label": "Adres e-mail kontaktowy",
      "default": "kontakt@roadandrolls.pl"
    }
  ]
}
{% endschema %}
